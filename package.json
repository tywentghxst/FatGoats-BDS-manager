{
  "name": "react-example",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "bin": "dist/server.cjs",
  "pkg": {
    "assets": [
      "dist/**/*"
    ]
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --sourcemap --outfile=dist/server.cjs",
    "build:exe": "npm run build && npx pkg . --target node18-win-x64 --output bds-manager.exe --compress GZip",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "prismarine-auth": "^3.1.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
